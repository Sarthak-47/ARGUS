# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
# The PyInstaller-frozen Argus CLI the desktop app bundles as a resource —
# built fresh by CI (see packaging/argus.spec + .github/workflows/desktop-release.yml)
# right before the Tauri build, never committed.
gui/src-tauri/binaries/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Argus runtime artifacts
argus-report/
*.argus.json
.argus-cache/

# Node / GUI
node_modules/
gui/dist/
gui/src-tauri/target/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Secrets / local config
.env
*.local.toml

# Raw Claude Design export (reference for the GUI phase, not source)
_design_export/

# Locally dropped-in engine report for the browser dev build (never ship demo data)
gui/public/report.json

# Real auth credentials for authenticated scans — never commit
.argus-auth.toml
